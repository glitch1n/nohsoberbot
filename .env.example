# Copy this file to .env and fill in the values

# 1. Get from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# 2. Card number shown to participants at the end
CARD_NUMBER=1234 5678 9012 3456

# 3. Ticket price (without drink), in rubles
EVENT_TICKET_PRICE=500

# 4. Path/name of the Excel file to write data into (created automatically)
EXCEL_FILE=event_registrations.xlsx
